# --- Dependencies ---
node_modules/
jspm_packages/

# --- TypeScript / Build Artifacts ---
# We ignore 'dist' because it's generated by the Docker builder stage
dist/
*.tsbuildinfo

# --- Environment & Secrets ---
# Crucial: Never commit your local ports or Artifactory keys
.env
.env.local
.env.*.local

# --- Docker & Helm ---
# Ignore the packaged Helm chart (.tgz) created by 'helm package'
*.tgz
# Ignore Helm dependency charts if you add them later
charts/
# Docker logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE / System ---
.vscode/
.idea/
.DS_Store
thumbs.db

# --- QA Tools ---
# If you use Locust for performance tests
__pycache__/
.pytest_cache/