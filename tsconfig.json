  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",            // Where the files go
    "rootDir": "./src",            // Where the files start
    "esModuleInterop": true,
    "noEmitOnError": false,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "strict": false              // Faster for QA tools, less strict on types
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
